---
import '../styles/global.css';
import LanguageToggle from '../components/LanguageToggle.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        var lang = localStorage.getItem('lang') || 'cn';
        document.documentElement.setAttribute('data-lang', lang);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <div class="site-header__name">
          <a href={base}>WANG YUXIANG</a>
        </div>
        <div class="site-header__controls">
          <LanguageToggle />
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "4ed754ab83244873862418ce4e581f0e"}'></script><!-- End Cloudflare Web Analytics -->
  </body>
</html>
