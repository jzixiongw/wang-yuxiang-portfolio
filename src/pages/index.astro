---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { siteConfig } from '../data/site';
import { projects } from '../data/projects';

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);
---

<Layout title={`${siteConfig.name} - 作品集`}>
  <section class="hero">
    <h1 class="hero__name">{siteConfig.name}</h1>
    <p class="hero__school">{siteConfig.school}</p>
    <p class="hero__intro">{siteConfig.intro}</p>
    <ul class="hero__resume-items">
      {siteConfig.resumeItems.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="project-section">
    <h2 class="project-section__heading">主要项目</h2>
    <div class="project-grid">
      {featured.map((project) => (
        <ProjectCard
          href={`${base}/projects/${project.slug}/`}
          cover={`${base}${project.cover}`}
          title={project.title}
          // date removed
        />
      ))}
    </div>
  </section>

  {others.length > 0 && (
    <section class="project-section">
      <h2 class="project-section__heading">其他项目</h2>
      <div class="project-grid">
        {others.map((project) => (
          <ProjectCard
            href={`${base}/projects/${project.slug}/`}
            cover={`${base}${project.cover}`}
            title={project.title}
            // date removed
          />
        ))}
      </div>
    </section>
  )}
</Layout>
