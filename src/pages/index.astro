---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { siteConfig } from '../data/site';
import { siteConfigEn, ui } from '../data/i18n';
import { projects } from '../data/projects';

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);
---

<Layout title={`${siteConfig.name} - 作品集`}>
  <section class="hero">
    <canvas id="hero-dots" class="hero__dots" aria-hidden="true"></canvas>
    <div class="hero__deco-tl" aria-hidden="true">
      <div class="hero__deco-bracket"></div>
      <span class="hero__deco-slashes">/ / / / /</span>
    </div>
    <span class="hero__deco-plus" aria-hidden="true">+</span>
    <svg class="hero__deco-lines" aria-hidden="true" viewBox="0 0 260 160" fill="none" preserveAspectRatio="none">
      <line x1="0" y1="145" x2="250" y2="5" stroke="white" stroke-width="0.7" stroke-opacity="0.12"/>
      <line x1="0" y1="160" x2="210" y2="35" stroke="white" stroke-width="0.7" stroke-opacity="0.07"/>
    </svg>
    <div class="container hero__inner">
      <div class="hero__content">
        <h1 class="hero__name">
          <span class="lang-cn">{siteConfig.name}</span>
          <span class="lang-en">{siteConfigEn.name}</span>
        </h1>
        <p class="hero__school">
          <span class="lang-cn">{siteConfig.school}</span>
          <span class="lang-en">{siteConfigEn.school}</span>
        </p>
        <ul class="hero__resume-items lang-cn">
          {siteConfig.resumeItems.map((item) => <li>{item}</li>)}
        </ul>
        <ul class="hero__resume-items lang-en">
          {siteConfigEn.resumeItems.map((item) => <li>{item}</li>)}
        </ul>
        <p class="hero__intro">
          <span class="lang-cn">{siteConfig.intro}</span>
          <span class="lang-en">{siteConfigEn.intro}</span>
        </p>
      </div>
      <div class="hero__cta-wrap">
        <a class="hero__cta" href="#projects-root">
          <span class="lang-cn">查看作品</span>
          <span class="lang-en">View Works</span>
        </a>
      </div>
    </div>
  </section>

  <div id="projects-root" class="container projects-root">
    <section class="project-section" id="featured-section">
      <h2 class="project-section__heading">
        <span class="lang-cn">{ui.cn.featuredProjects}</span>
        <span class="lang-en">{ui.en.featuredProjects}</span>
      </h2>
      <div class="project-grid">
        {featured.map((project) => (
          <ProjectCard
            href={`${base}/projects/${project.slug}/`}
            cover={`${base}${project.cover}`}
            title={project.title}
            titleEn={project.titleEn}
          />
        ))}
      </div>
    </section>

    {others.length > 0 && (
      <section class="project-section">
        <h2 class="project-section__heading">
          <span class="lang-cn">{ui.cn.otherProjects}</span>
          <span class="lang-en">{ui.en.otherProjects}</span>
        </h2>
        <div class="project-grid">
          {others.map((project) => (
            <ProjectCard
              href={`${base}/projects/${project.slug}/`}
              cover={`${base}${project.cover}`}
              title={project.title}
              titleEn={project.titleEn}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<noscript>
  <style>.project-card { opacity: 1 !important; }</style>
</noscript>

<script is:inline>
  /* ── Wavy dot field ── */
  (function () {
    var canvas = document.getElementById('hero-dots');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var t = 0;
    var COLS = 58, ROWS = 15;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    function draw() {
      var W = canvas.width, H = canvas.height;
      ctx.clearRect(0, 0, W, H);
      t += 0.007;

      var startX = W * 0.16;
      var colStep = (W * 0.985 - startX) / (COLS - 1);
      var rowStep = H / (ROWS - 1);

      for (var row = 0; row < ROWS; row++) {
        for (var col = 0; col < COLS; col++) {
          var xFrac = col / (COLS - 1);
          var x = startX + col * colStep;

          var yBase = H * 0.03 + row * rowStep;
          var w1 = Math.sin(col * 0.27 + t * 0.9) * rowStep * 0.55;
          var w2 = Math.sin(col * 0.13 - row * 0.55 + t * 0.6) * rowStep * 0.3;
          var w3 = Math.sin(col * 0.055 + row * 0.9 + t * 0.4) * rowStep * 0.18;
          var y = yBase + w1 + w2 + w3;
          if (y < 0 || y > H) continue;

          var fadeX = Math.pow(xFrac, 0.4);
          var yFrac = row / (ROWS - 1);
          var edgeFade = Math.min(yFrac * 6, 1) * Math.min((1 - yFrac) * 6, 1);
          var leftCornerFade = Math.min(1, xFrac * 1.8 + yFrac * 0.3 + 0.15);
          var opacity = fadeX * edgeFade * leftCornerFade * 0.85;
          if (opacity < 0.005) continue;

          var r = 1.2 + xFrac * 0.5;
          ctx.beginPath();
          ctx.arc(x, y, r, 0, 6.283185);
          ctx.fillStyle = 'rgba(215,215,215,' + Math.min(opacity, 0.88).toFixed(3) + ')';
          ctx.fill();
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  })();

  /* ── Card entrance (Intersection Observer) ── */
  (function () {
    var cards = Array.from(document.querySelectorAll('.project-card'));
    if (!cards.length) return;
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('card--visible');
          observer.unobserve(entry.target);
          entry.target.addEventListener('transitionend', function () {
            entry.target.style.transitionDelay = '';
          }, { once: true });
        }
      });
    }, { threshold: 0.05 });
    cards.forEach(function (card, i) {
      card.style.transitionDelay = (i * 0.06) + 's';
      observer.observe(card);
    });
  })();
</script>
