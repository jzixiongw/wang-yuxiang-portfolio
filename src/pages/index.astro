---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { siteConfig } from '../data/site';
import { projects } from '../data/projects';

const base = import.meta.env.BASE_URL;
---

<Layout title={`${siteConfig.name} - 作品集`}>
  <section class="hero">
    <h1 class="hero__name">{siteConfig.name}</h1>
    <p class="hero__school">{siteConfig.school}</p>
    <p class="hero__intro">{siteConfig.intro}</p>
    <ul class="hero__resume-items">
      {siteConfig.resumeItems.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="project-grid">
    {projects.map((project) => (
      <ProjectCard
        href={`${base}projects/${project.slug}/`}
        cover={`${base}${project.cover.replace(/^\//, '')}`}
        title={project.title}
        date={project.date}
      />
    ))}
  </section>
</Layout>
