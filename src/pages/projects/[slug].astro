---
import Layout from '../../layouts/Layout.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import VideoGrid from '../../components/VideoGrid.astro';
import { projects } from '../../data/projects';
import { ui } from '../../data/i18n';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
};

const { project } = Astro.props;
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');

---

<Layout title={`${project.title} - 王宇翔`}>
  <div class="container">
  <div class="project-detail">
    <a class="back-link" href={`${base}/`}>
      <span class="lang-cn">{ui.cn.backHome}</span>
      <span class="lang-en">{ui.en.backHome}</span>
    </a>
    {project.pdfUrl ? (
      <h1 class="project-detail__title">
        <span class="lang-cn">{project.title}</span>
        <span class="lang-en">{project.titleEn}</span>
      </h1>
      <p class="project-detail__description">
        <span class="lang-cn">{project.description}</span>
        <span class="lang-en">{project.descriptionEn}</span>
      </p>
      <div class="project-detail__pdf">
        <iframe
          src={`${base}${project.pdfUrl}`}
          width="100%"
          style="height:85vh;border:none;border-radius:8px;"
        ></iframe>
      </div>
    ) : (
      <>
        <img
          class="project-detail__cover"
          src={`${base}${project.cover}`}
          alt={project.title}
        />
        <h1 class="project-detail__title">
          <span class="lang-cn">{project.title}</span>
          <span class="lang-en">{project.titleEn}</span>
        </h1>
        <p class="project-detail__description">
          <span class="lang-cn">{project.description}</span>
          <span class="lang-en">{project.descriptionEn}</span>
        </p>
        {project.videoItems
          ? <VideoGrid items={project.videoItems} />
          : project.vodEmbedUrls.length > 0
            ? project.vodEmbedUrls.map((url) => <VideoEmbed url={url} />)
            : <VideoEmbed url="" />
        }
      </>
    )}
  </div>
  </div>
</Layout>
