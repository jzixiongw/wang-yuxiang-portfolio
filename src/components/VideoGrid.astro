---
interface VideoItem {
  url: string;
  title: string;
  titleEn?: string;
  caption?: string;
  captionEn?: string;
}

interface Props {
  items: VideoItem[];
}

const { items } = Astro.props;
---

<div class="video-grid">
  {items.map((item) => {
    const isMp4 = item.url.endsWith('.mp4');
    return (
      <div class="video-grid__item">
        <div class="video-grid__wrapper">
          {isMp4 ? (
            <video
              src={item.url}
              controls
              autoplay
              muted
              loop
              playsinline
              style="position:absolute;top:0;left:0;width:100%;height:100%;"
            ></video>
          ) : (
            <iframe
              src={item.url}
              allowfullscreen
              allow="autoplay; encrypted-media"
              loading="lazy"
            ></iframe>
          )}
        </div>
        <div class="video-grid__info">
          <div class="video-grid__title">
            <span class="lang-cn">{item.title}</span>
            {item.titleEn && <span class="lang-en">{item.titleEn}</span>}
          </div>
          {(item.caption || item.captionEn) && (
            <div class="video-grid__caption">
              {item.caption && <span class="lang-cn">{item.caption}</span>}
              {item.captionEn && <span class="lang-en">{item.captionEn}</span>}
            </div>
          )}
        </div>
      </div>
    );
  })}
</div>
