---
interface Props {
  url: string;
}

const { url } = Astro.props;
const isPlaceholder = !url || url.includes('placeholder') || url.includes('example.com');
const isMp4 = !isPlaceholder && url.endsWith('.mp4');
---

<div class="video-embed">
  <div class="video-embed__wrapper">
    {isPlaceholder ? (
      <div class="video-embed__placeholder">视频嵌入区域（请替换为真实腾讯云 VOD 嵌入链接）</div>
    ) : isMp4 ? (
      <video
        src={url}
        controls
        autoplay
        muted
        loop
        playsinline
        style="position:absolute;top:0;left:0;width:100%;height:100%;"
      ></video>
    ) : (
      <iframe
        src={url}
        allowfullscreen
        allow="autoplay; encrypted-media"
        loading="lazy"
      ></iframe>
    )}
  </div>
</div>
