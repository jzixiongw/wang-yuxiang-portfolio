---
interface Props {
  href: string;
  cover: string;
  title: string;
  date: string;
}

const { href, cover, title, date } = Astro.props;
---

<a class="project-card" href={href}>
  <img class="project-card__cover" src={cover} alt={title} loading="lazy" />
  <div class="project-card__info">
    <div class="project-card__title">{title}</div>
    <div class="project-card__date">{date}</div>
  </div>
</a>
